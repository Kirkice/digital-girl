# Digital Girl local configuration template

# PC backend
DIGITAL_GIRL_HOST=0.0.0.0
DIGITAL_GIRL_PORT=8010

# LiveTalking
LIVETALKING_MODEL=wav2lip
LIVETALKING_AVATAR_ID=wav2lip256_avatar1
LIVETALKING_TRANSPORT=webrtc

# LLM, use an OpenAI-compatible endpoint first
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-model-name
LLM_API_KEY=replace_me

# TTS
TTS_PROVIDER=edgetts
TTS_REF_FILE=zh-CN-XiaoxiaoNeural
TTS_SERVER=http://127.0.0.1:9880

# Privacy
ALLOW_PUBLIC_NETWORK=false
ENABLE_AUTH=false
