# Legacy companion-core runtime configuration.
# Prefer backend/config/companion-core.toml for local setup.
# This env file format is kept for compatibility only.
# Set COMPANION_CORE_ENV_FILE to override the legacy env config path.

COMPANION_CORE_HOST=127.0.0.1
COMPANION_CORE_PORT=8787

DIGITAL_GIRL_PERSONA_NAME=Digital Girl
DIGITAL_GIRL_PERSONA_SUMMARY=A warm, playful, private AI companion.
DIGITAL_GIRL_SYSTEM_PROMPT=You are a warm, concise, emotionally attentive companion. Reply naturally and avoid long lectures.

# Optional OpenAI-compatible provider. If these are not set, companion-core uses local placeholder replies.
# Example: LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=
LLM_MODEL=qwen-plus
LLM_API_KEY=
